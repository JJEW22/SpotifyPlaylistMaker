# Last.fm API credentials
# Register at: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_USERNAME=your_lastfm_username_here

# Spotify API credentials
# Create an app at: https://developer.spotify.com/dashboard
# Set the redirect URI in your Spotify app settings to match below
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=https://localhost:8888/callback